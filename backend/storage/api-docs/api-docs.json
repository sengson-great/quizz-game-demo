        "/games/{session}": {
            "get": {
                "tags": [
                    "Game"
                ],
                "summary": "Get an active game session state",
                "operationId": "11877bd8ba37bd6c962da8a8050ac224",
                "parameters": [
                    {
                        "name": "session",
                        "in": "path",
                        "description": "Game Session ID",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Session and current question details"
                    },
                    "403": {
                        "description": "Forbidden/Not owner of session"
                    }
                }
            }
        },
        "/games/{session}/answer": {
            "post": {
                "tags": [
                    "Game"
                ],
                "summary": "Submit an answer for the current question",
                "operationId": "e1f5263ae3c44d56a1290500b64a0cd1",
                "parameters": [
                    {
                        "name": "session",
                        "in": "path",
                        "description": "Game Session ID",
                        "required": true
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "answer_id"
                                ],
                                "properties": {
                                    "answer_id": {
                                        "type": "integer",
                                        "example": 123
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Answer evaluation result (correct/wrong) and optional next question"
                    },
                    "400": {
                        "description": "Game already ended"
                    },
                    "403": {
                        "description": "Forbidden"
                    }
                }
            }
        },
        "/games/{session}/lifeline": {
            "post": {
                "tags": [
                    "Game"
                ],
                "summary": "Use a lifeline for the current question",
                "operationId": "54e842a2abc137f3f10db6147d967a1c",
                "parameters": [
                    {
                        "name": "session",
                        "in": "path",
                        "description": "Game Session ID",
                        "required": true
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "type"
                                ],
                                "properties": {
                                    "type": {
                                        "description": "Name of lifeline (e.g. fiftyFifty, skip, audienceVote, phoneFriend)",
                                        "type": "string",
                                        "example": "fiftyFifty"
                                    },
                                    "question_id": {
                                        "description": "ID of the question (for lifelines that need it)",
                                        "type": "integer",
                                        "example": 45
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Result of using the lifeline (e.g. hidden answers or next question)"
                    },
                    "403": {
                        "description": "Forbidden"
                    }
                }
            }
        },
